   "source": [
    "from monitoring.drift_adwin import check_drift\n",
    "import numpy as np\n",
    "\n",
    "scores = np.random.rand(1000)\n",
    "labels = np.random.randint(0, 2, 1000)\n",
    "\n",
    "losses = np.abs(scores - labels)\n",
    "\n",
    "for loss in losses:\n",
    "    if check_drift(loss):\n",
    "        print(\"Drift detected\")\n",
    "        break\n"
   ]
  }
